---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import { projects, basics } from "@cv";
const { name, label } = basics;

const getProjectPriority = (project) => {
    if (project.isActive && !project.isFeatured) return 0;
    if (project.isActive && project.isFeatured) return 1;
    return 2;
};

const sortedProjects = [...projects].sort((a, b) => {
    const priority = getProjectPriority(a) - getProjectPriority(b);
    if (priority !== 0) return priority;

    return new Date(b.startDate).getTime() - new Date(a.startDate).getTime();
});

const getHighlights = (highlights) =>
    highlights.flatMap((highlight) =>
        highlight
            .split(",")
            .map((item) => item.trim())
            .filter(Boolean),
    );
---

<Layout title={`Proyectos de ${name} - ${label}`}>
    <main>
        <div class="page-header">
            <a href="/" class="back-link">&larr; Volver al inicio</a>
            <p>
                Una vista completa de proyectos propios, productos en desarrollo
                y aplicaciones construidas para practicar o resolver flujos
                reales.
            </p>
        </div>

        <div id="proyectos"></div>
        <Section title="Todos los Proyectos">
            <ul class="projects-list">
                {
                    sortedProjects.map(
                        (
                            {
                                url,
                                description,
                                name,
                                highlights,
                                isActive,
                                isFeatured,
                                description_url,
                            },
                            index,
                        ) => {
                            const projectHighlights = getHighlights(highlights);

                            return (
                                <li>
                                    <article
                                        class:list={[
                                            { "is-archived": !isActive },
                                        ]}
                                    >
                                        <div
                                            class="project-index"
                                            aria-hidden="true"
                                        >
                                            {(index + 1)
                                                .toString()
                                                .padStart(2, "0")}
                                        </div>
                                        <header>
                                            <div class="project-meta">
                                                {isActive ? (
                                                    <span class="status active">
                                                        Activo
                                                    </span>
                                                ) : (
                                                    <span class="status archived">
                                                        Archivado
                                                    </span>
                                                )}
                                                {isFeatured && (
                                                    <span class="status featured">
                                                        Destacado
                                                    </span>
                                                )}
                                            </div>
                                            <h3>{name}</h3>
                                            <p>{description}</p>
                                        </header>
                                        <footer>
                                            <ul class="stack-list">
                                                {projectHighlights.map(
                                                    (highlight) => {
                                                        return (
                                                            <li>{highlight}</li>
                                                        );
                                                    },
                                                )}
                                            </ul>
                                            <div class="project-actions">
                                                {description_url && (
                                                    <a
                                                        href={description_url}
                                                        class="description_url"
                                                    >
                                                        Ver detalle
                                                    </a>
                                                )}
                                                {url && (
                                                    <a
                                                        href={url}
                                                        title={`Ver el proyecto ${name}`}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        class="external_url"
                                                    >
                                                        Sitio
                                                    </a>
                                                )}
                                            </div>
                                        </footer>
                                    </article>
                                </li>
                            );
                        },
                    )
                }
            </ul>
        </Section>
    </main>

    <KeyboardManager />
</Layout>

<style>
    main {
        padding: 2rem;
        margin: auto;
        width: 100%;
    }

    .page-header {
        max-width: 700px;
        margin: 0 auto 2rem;
    }

    .back-link {
        display: inline-flex;
        color: var(--color-text-heading);
        font-size: 0.85rem;
        margin-bottom: 1rem;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .page-header p {
        max-width: 62ch;
        line-height: 1.6;
    }

    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        margin-inline: -16px;
    }

    article {
        position: relative;
        border-radius: 8px;
        border: 1px solid
            color-mix(in srgb, var(--color-border) 72%, #4f46e5 28%);
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--color-bg) 92%, #eef2ff 8%),
            color-mix(in srgb, var(--color-bg) 96%, #ecfeff 4%)
        );
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr) minmax(230px, 0.45fr);
        gap: 20px;
        align-items: start;
        padding: 20px;
        height: 100%;
        transition:
            border-color 0.2s ease,
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    article:hover {
        border-color: color-mix(
            in srgb,
            var(--color-border-hover) 45%,
            #14b8a6 55%
        );
        box-shadow: 0 14px 34px
            color-mix(in srgb, var(--color-text-heading) 9%, transparent);
        transform: translateX(3px);
    }

    article.is-archived {
        background: linear-gradient(
            135deg,
            color-mix(
                in srgb,
                var(--color-bg) 95%,
                var(--color-text-heading) 5%
            ),
            color-mix(in srgb, var(--color-bg) 97%, #64748b 3%)
        );
        opacity: 0.82;
    }

    .project-index {
        color: color-mix(in srgb, var(--color-text-heading) 34%, #14b8a6 66%);
        font-family: Menlo, Monaco, "Courier New", monospace;
        font-size: 1.45rem;
        font-weight: 700;
        line-height: 1;
        padding-top: 2px;
    }

    article header {
        min-width: 0;
    }

    article h3 {
        margin-bottom: 8px;
        font-size: 1rem;
        line-height: 1.35;
    }

    article a {
        color: var(--color-text-heading);
    }

    article a:hover {
        text-decoration: underline;
    }

    article p {
        font-size: 0.82rem;
        line-height: 1.55;
    }

    .project-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 12px;
    }

    .status {
        border: 1px solid
            color-mix(in srgb, var(--color-border) 70%, currentColor 30%);
        border-radius: 999px;
        color: var(--color-text-muted);
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0;
        padding: 0.18rem 0.5rem;
        text-transform: uppercase;
    }

    .status.active {
        background: color-mix(in srgb, #10b981 12%, transparent);
        border-color: color-mix(in srgb, #10b981 46%, var(--color-border));
        color: #047857;
    }

    .status.featured {
        background: color-mix(in srgb, #4f46e5 10%, transparent);
        border-color: color-mix(in srgb, #4f46e5 40%, var(--color-border));
        color: #4338ca;
    }

    .status.archived {
        background: color-mix(in srgb, #64748b 10%, transparent);
        color: var(--color-text-light);
    }

    footer {
        display: flex;
        flex-direction: column;
        gap: 14px;
        font-size: 0.7rem;
    }

    .stack-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .stack-list li {
        border-radius: 6px;
        background: color-mix(in srgb, var(--color-badge-bg) 75%, #e0f2fe 25%);
        border: 1px solid
            color-mix(in srgb, var(--color-border) 80%, #38bdf8 20%);
        color: var(--color-text-heading);
        font-size: 0.62rem;
        font-weight: 500;
        padding: 0.22rem 0.55rem;
    }

    .project-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .description_url,
    .external_url {
        border: 1px solid
            color-mix(in srgb, var(--color-border) 65%, #4f46e5 35%);
        border-radius: 6px;
        display: inline-flex;
        font-size: 0.72rem;
        padding: 0.42rem 0.62rem;
        transition:
            background-color 0.2s ease,
            border-color 0.2s ease;
    }

    .description_url {
        background: color-mix(
            in srgb,
            var(--color-text-heading) 88%,
            #4f46e5 12%
        );
        border-color: color-mix(
            in srgb,
            var(--color-text-heading) 72%,
            #4f46e5 28%
        );
        color: var(--color-bg);
        font-weight: 700;
    }

    .description_url:hover,
    .external_url:hover {
        border-color: var(--color-border-hover);
        text-decoration: none;
    }

    .external_url:hover {
        background: color-mix(in srgb, var(--color-badge-bg) 72%, #ecfeff 28%);
    }

    :global(html.dark) article {
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--color-bg) 88%, #312e81 12%),
            color-mix(in srgb, var(--color-bg) 92%, #0f766e 8%)
        );
        border-color: color-mix(in srgb, var(--color-border) 70%, #818cf8 30%);
    }

    :global(html.dark) article.is-archived {
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--color-bg) 90%, #334155 10%),
            color-mix(in srgb, var(--color-bg) 96%, #64748b 4%)
        );
    }

    :global(html.dark) .status.active {
        color: #6ee7b7;
    }

    :global(html.dark) .status.featured {
        color: #c7d2fe;
    }

    :global(html.dark) .stack-list li {
        color: var(--color-text-subheading);
    }

    :global(html.dark) .description_url {
        background: #f4f4f5;
        border-color: #f4f4f5;
        color: #111;
    }

    :global(html.dark) .description_url:hover {
        background: #e4e4e7;
        border-color: #e4e4e7;
    }

    @media (width <= 700px) {
        .projects-list {
            margin-inline: 0px;
        }

        article {
            grid-template-columns: 1fr;
            gap: 14px;
        }

        .project-index {
            font-size: 1rem;
        }
    }

    @media print {
        article {
            break-inside: avoid;
            transform: none !important;
        }
    }
</style>
